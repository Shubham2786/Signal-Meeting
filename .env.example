# ─────────────────────────────────────────────────────────────
# Signal Meetings — environment configuration
# Copy to .env and fill in real values. The app BOOTS AND RUNS FULLY in
# Stub mode with NO real keys (deterministic seed data).
# ─────────────────────────────────────────────────────────────

# --- AI provider selection: stub | gemini | groq ---
AI_PROVIDER=stub

# --- Groq (OpenAI-compatible endpoint; text + Whisper audio) ---
# Supports one or two keys; the second is used for failover/rate-limit rotation.
GROQ_API_KEY=__REPLACE_ME__
GROQ_API_KEY_2=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_TEXT_MODEL=llama-3.3-70b-versatile
GROQ_AUDIO_MODEL=whisper-large-v3

# --- Gemini (text via OpenAI-compatible endpoint; audio via @google/genai) ---
GEMINI_API_KEY=__REPLACE_ME__
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
GEMINI_TEXT_MODEL=gemini-2.5-flash
GEMINI_AUDIO_MODEL=gemini-2.5-pro

# --- Database: sqlite | supabase ---
# supabase auto-falls back to sqlite until SUPABASE_* keys are provided.
DATABASE_PROVIDER=sqlite
DATABASE_URL=file:./data/signal.db
SUPABASE_URL=__REPLACE_ME__
SUPABASE_SERVICE_ROLE_KEY=__REPLACE_ME__

# --- GitHub (optional; degrades gracefully if absent) ---
GITHUB_TOKEN=__REPLACE_ME__
GITHUB_REPO=owner/repo

# --- Server ---
PORT=8080
AUTO_CONFIRM_CONFIDENCE=0.8

# --- Lemma platform (future migration target) ---
LEMMA_DEFAULT_MODEL_TYPE=openai_compat
LEMMA_OPENAI_API_KEY=__REPLACE_ME__
LEMMA_OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
LEMMA_OPENAI_DEFAULT_MODEL=gemini-2.5-flash
LEMMA_OPENAI_MODEL_NAMES=gemini-2.5-flash,gemini-2.5-pro
LEMMA_OPENAI_VISION_MODEL_NAMES=gemini-2.5-pro
LEMMA_BASE_URL=http://127-0-0-1.sslip.io:8711
LEMMA_TOKEN=__REPLACE_ME__
