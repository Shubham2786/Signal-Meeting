{
    // Shared team data — the execution board everyone works on together.
    // id / created_at / updated_at are system-managed; never declare them.
    "name": "action_items",
    "primary_key_column": "id",
    "enable_rls": false,
    "columns": [
        {
            "name": "meeting_id",
            "type": "UUID",
            "required": true,
            "foreign_key": {
                "references": "meetings.id"
            }
        },
        {
            "name": "title",
            "type": "TEXT",
            "required": true,
            "max_length": 500
        },
        {
            "name": "owner",
            "type": "TEXT",
            "default": "Unassigned"
        },
        {
            "name": "due_date",
            "type": "DATE"
        },
        {
            "name": "follow_up",
            "type": "TEXT"
        },
        {
            "name": "source_quote",
            "type": "TEXT"
        },
        {
            "name": "confidence",
            "type": "FLOAT",
            "default": 0.5
        },
        {
            "name": "status",
            "type": "ENUM",
            "required": true,
            "default": "open",
            "options": [
                "open",
                "in_progress",
                "done"
            ]
        },
        {
            "name": "confirmed",
            "type": "BOOLEAN",
            "default": false
        },
        {
            "name": "duplicate_of",
            "type": "TEXT"
        }
    ],
    "config": {}
}